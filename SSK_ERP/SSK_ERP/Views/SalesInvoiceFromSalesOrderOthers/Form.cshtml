        function toIsoDate(val) {
            if (!val) return '';
            // Handle ASP.NET JSON date format: /Date(1772044200000)/
            if (typeof val === 'string' && val.indexOf('/Date(') === 0) {
                var ms = parseInt(val.substr(6), 10);
                if (!isNaN(ms)) {
                    val = ms;
                }
            }

            var dt = new Date(val);
            if (isNaN(dt.getTime())) return '';
            var mm = (dt.getMonth() + 1).toString().padStart(2, '0');
            var dd = dt.getDate().toString().padStart(2, '0');
            return dt.getFullYear() + '-' + mm + '-' + dd;
        }

        function loadInvoiceData(invoiceId) {
            $.get('@Url.Action("GetInvoiceData", "SalesInvoiceFromSalesOrderOthers")', { invoiceId: invoiceId }, function (res) {
                if (!res || !res.success) {
                    isLoadingEdit = false;
                    return;
