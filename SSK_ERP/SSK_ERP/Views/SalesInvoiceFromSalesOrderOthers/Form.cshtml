                    tr.append('<td><input type="number" class="form-control form-control-sm text-end row-qty" value="' + (itm.Qty || 0) + '" min="0" step="0.001" readonly="readonly" /></td>');
                    tr.append('<td><input type="hidden" class="row-actualrate" value="0.00" /><input type="number" class="form-control form-control-sm text-end row-rate" value="' + (itm.Rate || 0).toFixed(2) + '" min="0" step="0.01" /></td>');
                    tr.append('<td><input type="number" class="form-control form-control-sm text-end row-ptr" value="0.00" min="0" step="0.01" /></td>');
                    tr.append('<td><input type="number" class="form-control form-control-sm text-end row-mrp" value="0.00" min="0" step="0.01" /></td>');
                    tr.append('<td><input type="text" class="form-control form-control-sm text-end row-amount" value="0.00" readonly="readonly" /></td>');
                    tbody.append(tr);

                    recalcRow(tr);
                });

                recalcTotals();
                updateManualSummaryFromRows([]);

                $('#chkAll').prop('checked', (res.items || []).length > 0);
            });
        }

        function recalcRow($tr) {
            var qty = parseDecimal($tr.find('.row-qty').val() || '0');
            var rate = parseDecimal($tr.find('.row-rate').val() || '0');
            if (isNaN(qty)) qty = 0;
            if (isNaN(rate)) rate = 0;

            var amount = qty * rate;
            $tr.find('.row-amount').val(amount.toFixed(2));
        }

        function recalcTotals() {
            var stateType = parseInt($('#stateTypeDropdown').val() || '0', 10);

            var gross = 0;
            var cgst = 0;
            var sgst = 0;
            var igst = 0;

            $('#invoiceDetailsBody tr').each(function () {
                var $tr = $(this);

                var isSelected = $tr.find('.row-select').is(':checked');
                if (!isSelected) return;

                var amt = parseDecimal($tr.find('.row-amount').val() || '0');
                if (amt <= 0) return;

                var cgstRate = parseDecimal($tr.data('cgst') || '0');
                var sgstRate = parseDecimal($tr.data('sgst') || '0');
                var igstRate = parseDecimal($tr.data('igst') || '0');

                gross += amt;

                if (stateType === 0) {
                    if (cgstRate > 0) {
                        cgst += Math.round(((amt * cgstRate) / 100) * 100) / 100;
                    }
                    if (sgstRate > 0) {
                        sgst += Math.round(((amt * sgstRate) / 100) * 100) / 100;
                    }
                } else {
                    if (igstRate > 0) {
                        igst += Math.round(((amt * igstRate) / 100) * 100) / 100;
                    }
                }
            });

            var net = gross + cgst + sgst + igst;

            $('#siGrossAmt').val(gross.toFixed(2));
            $('#siCgstAmt').val(cgst.toFixed(2));
            $('#siSgstAmt').val(sgst.toFixed(2));
            $('#siIgstAmt').val(igst.toFixed(2));
            $('#selectedTotal').data('raw', net).val(net.toFixed(2));
            $('#siInvoiceAmt').data('raw', net).val(net.toFixed(2));
            updateInvoiceRoundOff();
        }
    </script>
}
