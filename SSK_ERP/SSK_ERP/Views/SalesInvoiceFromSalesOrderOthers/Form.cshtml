@model SSK_ERP.Models.TransactionMaster

@{
    ViewBag.Title = "Sales Invoice";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    .main-container {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        padding: 20px 0;
    }

    .form-container {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 15px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        margin: 20px;
        overflow: hidden;
    }

    .form-header {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        color: white;
        padding: 25px 30px;
        border-radius: 15px 15px 0 0;
    }

    .form-title {
        font-size: 28px;
        font-weight: 600;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .form-body {
        padding: 30px;
        background: white;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .control-label {
        font-weight: 600;
        color: #2d3436;
        margin-bottom: 8px;
        display: block;
    }

    .req {
        color: #e74c3c;
        font-weight: bold;
    }

    .form-control {
        border: 2px solid #c5ced8;
        border-radius: 8px;
        padding: 12px 15px;
        font-size: 14px;
        transition: all 0.3s ease;
        background-color: #edf1f7;
        color: #212529;
    }

    .form-control:focus {
        border-color: #4facfe;
        box-shadow: 0 0 0 0.2rem rgba(79, 172, 254, 0.25);
        background-color: white;
    }

    .btn-primary {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        border: none;
        padding: 12px 30px;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(79, 172, 254, 0.4);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(79, 172, 254, 0.6);
    }

    .btn-secondary {
        background: linear-gradient(135deg, #6c757d, #495057);
        border: none;
        padding: 12px 30px;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        color: white;
    }

    .btn-secondary:hover {
        transform: translateY(-2px);
        color: white;
    }

    .section-title {
        font-size: 18px;
        font-weight: 600;
        color: #2d3436;
        margin: 10px 0 20px 0;
        padding-bottom: 10px;
        border-bottom: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .so-detail-table {
        min-width: 1400px;
    }

    .so-detail-table thead th {
        background-color: #337ab7;
        color: #fff;
        text-align: center;
        font-size: 12px;
        vertical-align: middle;
        white-space: nowrap;
        padding: 10px;
    }

    .so-detail-table tbody td {
        vertical-align: middle;
        font-size: 12px;
        padding: 5px;
    }

    .so-detail-table .form-control-sm {
        padding: 5px;
        height: 32px;
    }

    .so-detail-table .select2-container {
        width: 100% !important;
    }

    .so-detail-table .select2-container .select2-selection--single {
        height: 32px;
    }

    .so-tax-table {
        margin-bottom: 0;
    }

    .so-tax-table td {
        vertical-align: middle;
        font-size: 13px;
    }

    .so-tax-summary-label {
        text-align: right;
        font-weight: 600;
        width: 150px;
        white-space: nowrap;
    }

    .form-control.is-invalid {
        border-color: #dc3545;
        box-shadow: 0 0 0 0.2rem rgba(220,53,69,0.15);
    }
</style>

<div class="main-container">
    <div class="form-container">
        <div class="form-header">
            <h2 class="form-title">
                <span>Sales Invoice From Sales Order (Others)</span>
            </h2>
        </div>

        <div class="form-body">
            @using (Html.BeginForm("savedata", "SalesInvoiceFromSalesOrderOthers", FormMethod.Post, new { id = "salesInvoiceOthersForm" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.TRANMID)
                @Html.HiddenFor(m => m.TRANNO)
                @Html.HiddenFor(m => m.TRANDNO)

                if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger" role="alert">@TempData["ErrorMessage"]</div>
                }
                if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success" role="alert">@TempData["SuccessMessage"]</div>
                }

                <input type="hidden" id="salesOrderId" name="salesOrderId" value="0" />

                <div class="section-title">
                    <span>Invoice Details</span>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label">No</label>
                            @Html.TextBoxFor(m => m.TRANNO, new { @class = "form-control", @readonly = "readonly" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label">Date</label>
                            @Html.TextBoxFor(m => m.TRANDATE, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label">Status</label>
                            @Html.DropDownListFor(m => m.DISPSTATUS, ViewBag.StatusList as SelectList, new { @class = "form-control", id = "statusDropdown" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="control-label">Customer Name <span class="req">*</span></label>
                            <select id="customerDropdown" class="form-control"></select>
                        </div>
                        @Html.HiddenFor(m => m.TRANREFID, new { id = "tranRefId" })
                        @Html.HiddenFor(m => m.TRANREFNAME, new { id = "tranRefName" })
                        @Html.HiddenFor(m => m.TRANSTATETYPE, new { id = "stateTypeDropdown" })
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="control-label">Bill No <span class="req">*</span></label>
                            <select id="billNoDropdown" class="form-control"></select>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label">Credit Days</label>
                            @Html.TextBoxFor(m => m.TRAN_CRDPRDT, new { @class = "form-control", type = "number", min = "0", step = "1" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label">Ref No</label>
                            @Html.TextBoxFor(m => m.TRANTAXBILLNO, new { @class = "form-control", placeholder = "Ref No" })
                        </div>
                    </div>
                </div>

                <div class="section-title">
                    <span>Customer Details</span>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="row mb-2">
                            <div class="col-md-6">
                                <input type="text" id="custNameOrAddr" class="form-control" placeholder="Customer Name" readonly="readonly" />
                            </div>
                            <div class="col-md-6">
                                <input type="text" id="custAddress1" class="form-control" placeholder="Address" readonly="readonly" />
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-md-6">
                                <input type="text" id="custCity" class="form-control" placeholder="City" readonly="readonly" />
                            </div>
                            <div class="col-md-6">
                                <input type="text" id="custState" class="form-control" placeholder="State" readonly="readonly" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <input type="text" id="custPincode" class="form-control" placeholder="Pincode" readonly="readonly" />
                            </div>
                            <div class="col-md-6">
                                <input type="text" id="custCountry" class="form-control" placeholder="Country" readonly="readonly" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="section-title">
                    <span>Item Details</span>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle so-detail-table">
                        <thead>
                            <tr>
                                <th style="width:40px;" class="text-center">
                                    <input type="checkbox" id="chkAll" />
                                </th>
                                <th style="width:50px;" class="text-center">S.No</th>
                                <th style="width:200px;">Material</th>
                                <th style="width:120px;">HSN Code</th>
                                <th style="width:110px;">Batch No</th>
                                <th style="width:120px;">Exp Date</th>
                                <th style="width:120px;">Packing</th>
                                <th style="width:80px;" class="text-end">No of Boxes</th>
                                <th style="width:80px;" class="text-end">Qty</th>
                                <th style="width:100px;" class="text-end">Price Unit</th>
                                <th style="width:100px;" class="text-end">PTR</th>
                                <th style="width:100px;" class="text-end">MRP</th>
                                <th style="width:120px;" class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="invoiceDetailsBody"></tbody>
                    </table>
                </div>

                <div class="row" style="margin-top: 10px;">
                    <div class="col-md-12">
                        <table class="table table-bordered so-tax-table">
                            <tr>
                                <td class="col-md-4">
                                    <button type="button" class="btn btn-success btn-sm" id="siTaxToggle">
                                        <i class="fa fa-plus-square"></i> TAX
                                    </button>
                                </td>
                                <td class="so-tax-summary-label">Gross Amount</td>
                                <td class="col-md-2">
                                    <input type="text" id="siGrossAmt" class="form-control text-end" readonly="readonly" value="0.00" />
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                                <td class="so-tax-summary-label">CGST</td>
                                <td>
                                    <input type="text" id="siCgstAmt" class="form-control text-end" readonly="readonly" value="0.00" />
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                                <td class="so-tax-summary-label">SGST</td>
                                <td>
                                    <input type="text" id="siSgstAmt" class="form-control text-end" readonly="readonly" value="0.00" />
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                                <td class="so-tax-summary-label">IGST</td>
                                <td>
                                    <input type="text" id="siIgstAmt" class="form-control text-end" readonly="readonly" value="0.00" />
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                                <td class="so-tax-summary-label">Discount Amount</td>
                                <td>
                                    <input type="text" id="siDiscountAmt" class="form-control text-end" readonly="readonly" value="0.00" />
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                                <td class="so-tax-summary-label">Courier Charges</td>
                                <td>
                                    <input type="text" id="siCourierAmt" class="form-control text-end" readonly="readonly" value="0.00" />
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                                <td class="so-tax-summary-label">Selected Net Amount</td>
                                <td>
                                    <input type="text" id="selectedTotal" class="form-control text-end" readonly="readonly" value="0.00" />
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                                <td class="so-tax-summary-label">Round Off</td>
                                <td>
                                    @Html.TextBoxFor(m => m.TRANROAMT, new { @class = "form-control text-end", id = "siRoundOffAmt", @readonly = "readonly" })
                                </td>
                            </tr>
                            <tr>
                                <td></td>
                                <td class="so-tax-summary-label">Invoice Amount</td>
                                <td>
                                    <input type="text" id="siInvoiceAmt" class="form-control text-end" readonly="readonly" value="0.00" />
                                </td>
                            </tr>
                        </table>
                        <input type="hidden" id="siTaxDataJson" name="TaxFactorsJson" value="" />
                    </div>
                </div>

                <div class="section-title">
                    <span>Remarks</span>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        @Html.TextAreaFor(m => m.TRANRMKS, new { @class = "form-control", rows = 3 })
                    </div>
                </div>

                <div class="form-actions mt-3">
                    <a href="@Url.Action("Index", "SalesInvoice")" class="btn btn-secondary">Back</a>
                    <input type="hidden" id="detailRowsJson" name="detailRowsJson" />
                    <button type="submit" id="btnSave" class="btn btn-primary">Save</button>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="siTaxModal" tabindex="-1" role="dialog" aria-labelledby="siTaxModalLabel" aria-hidden="true" data-backdrop="static">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="siTaxModalLabel">
                    <i class="fa fa-calculator"></i> Tax Calculation
                </h5>
                <button type="button" class="close" id="siTaxCloseHeader" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-12">
                        <button type="button" class="btn btn-primary btn-sm" id="siAddTaxRow">
                            <i class="fa fa-plus"></i> Add Row
                        </button>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered" id="siTaxTable">
                        <thead class="bg-light">
                            <tr>
                                <th style="width:5%">
                                </th>
                                <th style="width:30%">Cost Factor</th>
                                <th style="width:20%">Expression</th>
                                <th style="width:15%">Mode</th>
                                <th style="width:15%">Value</th>
                                <th style="width:15%">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="siTaxTableBody">
                        </tbody>
                        <tfoot>
                            <tr class="bg-light">
                                <td colspan="5" class="text-end"><strong>Total Add Amount:</strong></td>
                                <td><strong id="siTotalAddAmount">0.00</strong></td>
                            </tr>
                            <tr class="bg-light">
                                <td colspan="5" class="text-end"><strong>Total Less Amount:</strong></td>
                                <td><strong id="siTotalLessAmount">0.00</strong></td>
                            </tr>
                            <tr class="bg-light">
                                <td colspan="5" class="text-end"><strong>Total Tax Amount:</strong></td>
                                <td><strong id="siTotalTaxAmount">0.00</strong></td>
                            </tr>
                            <tr class="bg-success text-white">
                                <td colspan="5" class="text-end"><strong>Grand Total (Net + Tax):</strong></td>
                                <td><strong id="siGrandTotal">0.00</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="siTaxCloseFooter" data-dismiss="modal">
                    <i class="fa fa-times"></i> Close
                </button>
                <button type="button" class="btn btn-primary" id="siApplyTax">
                    <i class="fa fa-check"></i> Apply
                </button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        var packingOptionsHtml = '<option value=""></option>';

        function parseDecimal(val) {
            var n = parseFloat(val);
            return isNaN(n) ? 0 : n;
        }

        var siCostFactorOptionsHtml = '<option value="">-- Select Cost Factor --</option>';
        var siTaxData = [];
        var siCostFactorMeta = {};
        var siCostFactorLoaded = false;

        var isLoadingEdit = false;
        var suppressCustomerChange = false;
        var suppressBillChange = false;

        function getInvoiceIdFromUrl() {
            try {
                var path = (window.location && window.location.pathname) ? window.location.pathname : '';
                if (!path) return 0;
                var parts = path.split('/').filter(function (p) { return p && p.trim() !== ''; });
                if (!parts || parts.length === 0) return 0;
                var last = parts[parts.length - 1];
                var n = parseInt(last, 10);
                return isNaN(n) ? 0 : n;
            } catch (e) {
                return 0;
            }
        }

        $(document).ready(function () {
            var serverErrorMsg = '@(TempData["ErrorMessage"] != null ? HttpUtility.JavaScriptStringEncode(TempData["ErrorMessage"].ToString()) : "")';
            var serverSuccessMsg = '@(TempData["SuccessMessage"] != null ? HttpUtility.JavaScriptStringEncode(TempData["SuccessMessage"].ToString()) : "")';
            if (typeof Swal !== 'undefined' && Swal.fire) {
                if (serverErrorMsg) {
                    Swal.fire({ title: 'Error', text: serverErrorMsg, icon: 'error' });
                } else if (serverSuccessMsg) {
                    Swal.fire({ title: 'Success', text: serverSuccessMsg, icon: 'success' });
                }
            }

            $('#customerDropdown').select2({ width: '100%', placeholder: '-- Select Customer --' });
            $('#billNoDropdown').select2({ width: '100%', placeholder: '-- Select Bill No --' });

            var invoiceId = parseInt($('#TRANMID').val() || '0', 10);
            if (invoiceId <= 0) {
                invoiceId = getInvoiceIdFromUrl();
                if (invoiceId > 0) {
                    $('#TRANMID').val(invoiceId);
                }
            }
            if (invoiceId > 0) {
                isLoadingEdit = true;
                loadPackings(function () {
                    loadCustomers(function () {
                        loadInvoiceData(invoiceId);
                    });
                });
            } else {
                loadPackings();
                loadCustomers();
            }

            $('#customerDropdown').on('change', function () {
                if (suppressCustomerChange) {
                    suppressCustomerChange = false;
                    return;
                }
                var customerId = parseInt($(this).val() || '0', 10);
                $('#tranRefId').val(customerId);
                $('#tranRefName').val($('#customerDropdown option:selected').text());
                $('#billNoDropdown').empty().trigger('change');
                if (!isLoadingEdit) {
                    clearHeaderAndGrid();
                }

                if (customerId > 0) {
                    loadBillNos(customerId);
                }
            });

            $('#billNoDropdown').on('change', function () {
                if (suppressBillChange) {
                    suppressBillChange = false;
                    return;
                }
                var soId = parseInt($(this).val() || '0', 10);
                $('#salesOrderId').val(soId);
                if (!isLoadingEdit) {
                    clearHeaderAndGrid();
                }

                var invoiceId = parseInt($('#TRANMID').val() || '0', 10);
                // Only load Sales Order rows for NEW invoices. In edit, always keep saved invoice rows.
                if (soId > 0 && !isLoadingEdit && invoiceId <= 0) {
                    loadSalesOrderData(soId);
                }
            });

            $(document).on('input', '.row-rate, .row-actualrate', function () {
                var $tr = $(this).closest('tr');
                recalcRow($tr);
                recalcTotals();
                updateManualSummaryFromRows(siTaxData);
            });

            $('#chkAll').on('change', function () {
                var isChecked = $(this).is(':checked');
                $('#invoiceDetailsBody .row-select').prop('checked', isChecked);
                recalcTotals();
                updateManualSummaryFromRows(siTaxData);
            });

            $(document).on('change', '#invoiceDetailsBody .row-select', function () {
                var total = $('#invoiceDetailsBody .row-select').length;
                var checked = $('#invoiceDetailsBody .row-select:checked').length;
                $('#chkAll').prop('checked', total > 0 && total === checked);

                recalcTotals();
                updateManualSummaryFromRows(siTaxData);
            });

            $('#siTaxToggle').on('click', function () {
                openSiTaxModal();
            });

            $('#siTaxCloseHeader, #siTaxCloseFooter').on('click', function () {
                $('#siTaxModal').modal('hide');
            });

            $('#siAddTaxRow').on('click', function () {
                addSiTaxRow();
            });

            $(document).on('click', '.si-tax-row-delete', function () {
                var $rows = $('#siTaxTableBody tr');
                if ($rows.length > 1) {
                    $(this).closest('tr').remove();
                } else {
                    $(this).closest('tr').find('select').prop('selectedIndex', 0);
                    $(this).closest('tr').find('.si-tax-value').val('0.000');
                    $(this).closest('tr').find('.si-tax-amount').val('0.00');
                }
                recalcSiTaxTotals();
                refreshSiCostFactorDropdowns();
            });

            $(document).on('change keyup', '.si-tax-type, .si-tax-mode, .si-tax-value', function () {
                recalcSiTaxTotals();
            });

            $(document).on('change', '.si-cost-factor', function () {
                refreshSiCostFactorDropdowns();
            });

            $('#siApplyTax').on('click', function () {
                siTaxData = collectSiTaxData();
                $('#siTaxDataJson').val(JSON.stringify(siTaxData));

                updateManualSummaryFromRows(siTaxData);

                $('#siTaxModal').modal('hide');
            });

            $(document).on('change', '.row-packing', function () {
                var $tr = $(this).closest('tr');
                var materialId = parseInt($tr.find('.row-materialid').val() || '0', 10);
                var packingId = parseInt($(this).val() || '0', 10);

                var $batch = $tr.find('.row-batch');
                $batch.empty();
                $batch.append('<option value=""></option>');

                if (materialId <= 0 || packingId <= 0) {
                    return;
                }

                $.get('@Url.Action("GetBatches", "SalesInvoiceFromSalesOrderOthers")', { materialId: materialId, packingId: packingId }, function (res) {
                    if (!res || !res.success) {
                        return;
                    }

                    var list = res.data || [];
                    list.forEach(function (b) {
                        $batch.append('<option value="' + b.BatchId + '">' + (b.BatchNo || '') + '</option>');
                    });

                    if (list.length > 0) {
                        $batch.val(list[0].BatchId);

                        var $exp = $tr.find('.row-expdate');
                        if ($exp.length && (!$exp.val() || ($exp.val() + '').trim() === '') && list[0].ExpiryDate) {
                            var dt = new Date(list[0].ExpiryDate);
                            if (!isNaN(dt.getTime())) {
                                var mm = (dt.getMonth() + 1).toString().padStart(2, '0');
                                var dd = dt.getDate().toString().padStart(2, '0');
                                $exp.val(dt.getFullYear() + '-' + mm + '-' + dd);
                            }
                        }
                    }
                });
            });

            $('#salesInvoiceOthersForm').on('submit', function (e) {
                e.preventDefault();

                var doSubmit = function () {
                    if (!validateForm()) {
                        if (typeof Swal !== 'undefined' && Swal.fire) {
                            Swal.fire({
                                title: 'Required',
                                text: 'Please select Customer, Bill No and ensure item rows are loaded.',
                                icon: 'warning'
                            });
                        } else {
                            alert('Please select Customer, Bill No and ensure item rows are loaded.');
                        }
                        return;
                    }

                    var rows = [];
                    $('#invoiceDetailsBody tr').each(function () {
                        var $tr = $(this);
                        var isSelected = $tr.find('.row-select').is(':checked');
                        if (!isSelected) {
                            return;
                        }
                        var materialId = parseInt($tr.find('.row-materialid').val() || '0', 10);
                        var qty = parseFloat($tr.find('.row-qty').val() || '0');
                        var rate = parseFloat($tr.find('.row-rate').val() || '0');
                        var actualRate = parseFloat($tr.find('.row-actualrate').val() || '0');
                        var amount = parseFloat($tr.find('.row-amount').val() || '0');
                        var packingId = parseInt($tr.find('.row-packing').val() || '0', 10);
                        var boxQty = parseFloat($tr.find('.row-boxqty').val() || '0');
                        var batchNo = ($tr.find('.row-batch option:selected').text() || '').trim();
                        var expDate = ($tr.find('.row-expdate').val() || '').trim();
                        var ptr = parseFloat($tr.find('.row-ptr').val() || '0');
                        var mrp = parseFloat($tr.find('.row-mrp').val() || '0');

                        if (materialId > 0 && qty > 0) {
                            rows.push({
                                MaterialId: materialId,
                                Qty: qty,
                                Rate: rate,
                                ActualRate: actualRate,
                                Amount: amount,
                                BatchNo: batchNo,
                                ExpiryDate: expDate,
                                PackingId: packingId,
                                BoxQty: boxQty,
                                Ptr: ptr,
                                Mrp: mrp
                            });
                        }
                    });

                    if (rows.length === 0) {
                        if (typeof Swal !== 'undefined' && Swal.fire) {
                            Swal.fire({
                                title: 'No Items Selected',
                                text: 'Please select at least one row to save.',
                                icon: 'warning'
                            });
                        } else {
                            alert('Please select at least one row to save.');
                        }
                        return;
                    }

                    $('#detailRowsJson').val(JSON.stringify(rows));
                    document.getElementById('salesInvoiceOthersForm').submit();
                };

                if (typeof Swal !== 'undefined' && Swal.fire) {
                    Swal.fire({
                        title: 'Confirm Save',
                        text: 'Do you want to save this Sales Invoice?',
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, Save',
                        cancelButtonText: 'Cancel'
                    }).then(function (result) {
                        if (result && result.isConfirmed) {
                            doSubmit();
                        }
                    });
                } else {
                    if (confirm('Do you want to save this Sales Invoice?')) {
                        doSubmit();
                    }
                }
            });

        });

