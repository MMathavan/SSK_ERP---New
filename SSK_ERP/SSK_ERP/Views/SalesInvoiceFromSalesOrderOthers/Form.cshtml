@model SSK_ERP.Models.TransactionMaster

@{
    ViewBag.Title = "Sales Invoice";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    .main-container {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        padding: 20px 0;
    }

    .form-container {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 15px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        margin: 20px;
        overflow: hidden;
    }

    .form-header {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        color: white;
        padding: 25px 30px;
        border-radius: 15px 15px 0 0;
    }

    .form-title {
        font-size: 28px;
        font-weight: 600;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .form-body {
        padding: 30px;
        background: white;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .control-label {
        font-weight: 600;
        color: #2d3436;
        margin-bottom: 8px;
        display: block;
    }

    .req {
        color: #e74c3c;
        font-weight: bold;
    }

    .form-control {
        border: 2px solid #c5ced8;
        border-radius: 8px;
        padding: 12px 15px;
        font-size: 14px;
        transition: all 0.3s ease;
        background-color: #edf1f7;
        color: #212529;
    }

    .form-control:focus {
        border-color: #4facfe;
        box-shadow: 0 0 0 0.2rem rgba(79, 172, 254, 0.25);
        background-color: white;
    }

    .btn-primary {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        border: none;
        padding: 12px 30px;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(79, 172, 254, 0.4);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(79, 172, 254, 0.6);
    }

    .btn-secondary {
        background: linear-gradient(135deg, #6c757d, #495057);
        border: none;
        padding: 12px 30px;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        color: white;
    }

    .btn-secondary:hover {
        transform: translateY(-2px);
        color: white;
    }

    .section-title {
        font-size: 18px;
        font-weight: 600;
        color: #2d3436;
        margin: 10px 0 20px 0;
        padding-bottom: 10px;
        border-bottom: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .so-detail-table {
        min-width: 1400px;
    }

    .so-detail-table thead th {
        background-color: #337ab7;
        color: #fff;
        text-align: center;
        font-size: 12px;
        vertical-align: middle;
        white-space: nowrap;
        padding: 10px;
    }

    .so-detail-table tbody td {
        vertical-align: middle;
        font-size: 12px;
        padding: 5px;
    }

    .so-detail-table .form-control-sm {
        padding: 5px;
        height: 32px;
    }

    .form-control.is-invalid {
        border-color: #dc3545;
        box-shadow: 0 0 0 0.2rem rgba(220,53,69,0.15);
    }
</style>

<div class="main-container">
    <div class="form-container">
        <div class="form-header">
            <h1 class="form-title">
                <i class="fa fa-file-invoice"></i>
                Sales Invoice (From Sales Order - Others)
                <span style="font-size: 0.6em; opacity: 0.8; margin-left: 10px;">#@(string.IsNullOrEmpty(Model.TRANDNO) ? "New" : Model.TRANDNO)</span>
            </h1>
        </div>

        <div class="form-body">
            @using (Html.BeginForm("savedata", "SalesInvoiceFromSalesOrderOthers", FormMethod.Post, new { id = "salesInvoiceOthersForm" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.TRANMID)
                @Html.HiddenFor(m => m.TRANNO)
                @Html.HiddenFor(m => m.TRANDNO)

                <input type="hidden" id="salesOrderId" name="salesOrderId" value="0" />

                <div class="section-title">
                    <i class="fa fa-info-circle"></i> Invoice Details
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label">No</label>
                            @Html.TextBoxFor(m => m.TRANNO, new { @class = "form-control", @readonly = "readonly" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label">Date</label>
                            @Html.TextBoxFor(m => m.TRANDATE, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="control-label">Status</label>
                            @Html.DropDownListFor(m => m.DISPSTATUS, ViewBag.StatusList as SelectList, new { @class = "form-control", id = "statusDropdown" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="control-label">Customer Name <span class="req">*</span></label>
                            <select id="customerDropdown" class="form-control"></select>
                        </div>
                        @Html.HiddenFor(m => m.TRANREFID, new { id = "tranRefId" })
                        @Html.HiddenFor(m => m.TRANREFNAME, new { id = "tranRefName" })
                        @Html.HiddenFor(m => m.TRANSTATETYPE, new { id = "stateTypeDropdown" })
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="control-label">Bill No <span class="req">*</span></label>
                            <select id="billNoDropdown" class="form-control"></select>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label">Credit Days</label>
                            @Html.TextBoxFor(m => m.TRAN_CRDPRDT, new { @class = "form-control", type = "number", min = "0", step = "1" })
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label">Ref No</label>
                            @Html.TextBoxFor(m => m.TRANTAXBILLNO, new { @class = "form-control", placeholder = "Ref No" })
                        </div>
                    </div>
                </div>

                <div class="section-title">Customer Address</div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="row mb-2">
                            <div class="col-md-6">
                                <input type="text" id="custNameOrAddr" class="form-control" placeholder="Customer Name" readonly="readonly" />
                            </div>
                            <div class="col-md-6">
                                <input type="text" id="custAddress1" class="form-control" placeholder="Address" readonly="readonly" />
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-md-6">
                                <input type="text" id="custCity" class="form-control" placeholder="City" readonly="readonly" />
                            </div>
                            <div class="col-md-6">
                                <input type="text" id="custState" class="form-control" placeholder="State" readonly="readonly" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <input type="text" id="custPincode" class="form-control" placeholder="Pincode" readonly="readonly" />
                            </div>
                            <div class="col-md-6">
                                <input type="text" id="custCountry" class="form-control" placeholder="Country" readonly="readonly" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="section-title">Item Details</div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle so-detail-table">
                        <thead>
                            <tr>
                                <th style="width: 50px;">S.No</th>
                                <th style="width: 200px;">Material</th>
                                <th style="width: 150px;">HSN Code</th>
                                <th style="width: 100px;">Batch No</th>
                                <th style="width: 120px;">Exp Date</th>
                                <th style="width: 120px;">Packing</th>
                                <th style="width: 80px;">No of Boxes</th>
                                <th style="width: 80px;">Qty</th>
                                <th style="width: 100px;">Price Unit</th>
                                <th style="width: 100px;">PTR</th>
                                <th style="width: 100px;">MRP</th>
                                <th style="width: 120px;">Amount</th>
                            </tr>
                        </thead>
                        <tbody id="invoiceDetailsBody"></tbody>
                    </table>
                </div>

                <div class="section-title">Remarks</div>
                <div class="row">
                    <div class="col-md-12">
                        @Html.TextAreaFor(m => m.TRANRMKS, new { @class = "form-control", rows = 3 })
                    </div>
                </div>

                <div class="form-actions mt-3">
                    <a href="@Url.Action("Index", "SalesInvoice")" class="btn btn-secondary">Back</a>
                    <input type="hidden" id="detailRowsJson" name="detailRowsJson" />
                    <button type="button" id="btnSave" class="btn btn-primary">Save</button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        var packingOptionsHtml = '<option value=""></option>';

        $(document).ready(function () {
            $('#customerDropdown').select2({ width: '100%', placeholder: '-- Select Customer --' });
            $('#billNoDropdown').select2({ width: '100%', placeholder: '-- Select Bill No --' });

            loadPackings();
            loadCustomers();

            $('#customerDropdown').on('change', function () {
                var customerId = parseInt($(this).val() || '0', 10);
                $('#tranRefId').val(customerId);
                $('#tranRefName').val($('#customerDropdown option:selected').text());
                $('#billNoDropdown').empty().trigger('change');
                clearHeaderAndGrid();

                if (customerId > 0) {
                    loadBillNos(customerId);
                }
            });

            $('#billNoDropdown').on('change', function () {
                var soId = parseInt($(this).val() || '0', 10);
                $('#salesOrderId').val(soId);
                clearHeaderAndGrid();

                if (soId > 0) {
                    loadSalesOrderData(soId);
                }
            });

            $(document).on('input', '.row-rate, .row-actualrate', function () {
                var $tr = $(this).closest('tr');
                recalcRow($tr);
            });

            $('#btnSave').on('click', function () {
                if (!validateForm()) {
                    return;
                }

                var rows = [];
                $('#invoiceDetailsBody tr').each(function () {
                    var $tr = $(this);
                    var materialId = parseInt($tr.find('.row-materialid').val() || '0', 10);
                    var qty = parseFloat($tr.find('.row-qty').val() || '0');
                    var rate = parseFloat($tr.find('.row-rate').val() || '0');
                    var actualRate = parseFloat($tr.find('.row-actualrate').val() || '0');
                    var amount = parseFloat($tr.find('.row-amount').val() || '0');

                    if (materialId > 0 && qty > 0) {
                        rows.push({
                            MaterialId: materialId,
                            Qty: qty,
                            Rate: rate,
                            ActualRate: actualRate,
                            Amount: amount
                        });
                    }
                });

                $('#detailRowsJson').val(JSON.stringify(rows));
                $('#salesInvoiceOthersForm').submit();
            });
        });

        function validateForm() {
            var isValid = true;

            var custId = parseInt($('#tranRefId').val() || '0', 10);
            if (custId <= 0) {
                isValid = false;
                $('#customerDropdown').next('.select2').find('.select2-selection').addClass('is-invalid');
            } else {
                $('#customerDropdown').next('.select2').find('.select2-selection').removeClass('is-invalid');
            }

            var soId = parseInt($('#salesOrderId').val() || '0', 10);
            if (soId <= 0) {
                isValid = false;
                $('#billNoDropdown').next('.select2').find('.select2-selection').addClass('is-invalid');
            } else {
                $('#billNoDropdown').next('.select2').find('.select2-selection').removeClass('is-invalid');
            }

            var rowCount = $('#invoiceDetailsBody tr').length;
            if (rowCount <= 0) {
                isValid = false;
            }

            return isValid;
        }

        function clearHeaderAndGrid() {
            $('#custNameOrAddr').val('');
            $('#custAddress1').val('');
            $('#custCity').val('');
            $('#custState').val('');
            $('#custPincode').val('');
            $('#custCountry').val('');
            $('#invoiceDetailsBody').empty();
            $('#stateTypeDropdown').val('0');
        }

        function loadPackings() {
            $.get('@Url.Action("GetPackings", "SalesInvoiceFromSalesOrderOthers")', function (res) {
                if (!res || !res.success) {
                    return;
                }

                var html = '<option value=""></option>';
                (res.data || []).forEach(function (p) {
                    html += '<option value="' + p.Id + '">' + (p.Name || '') + '</option>';
                });
                packingOptionsHtml = html;
            });
        }

        function loadCustomers() {
            $.get('@Url.Action("GetCustomers", "SalesInvoiceFromSalesOrderOthers")', function (res) {
                if (!res || !res.success) {
                    return;
                }

                var $ddl = $('#customerDropdown');
                $ddl.empty();
                $ddl.append('<option value=""></option>');

                (res.data || []).forEach(function (c) {
                    $ddl.append('<option value="' + c.Id + '">' + (c.Name || '') + '</option>');
                });

                $ddl.trigger('change');
            });
        }

        function loadBillNos(customerId) {
            $.get('@Url.Action("GetBillNos", "SalesInvoiceFromSalesOrderOthers")', { customerId: customerId }, function (res) {
                if (!res || !res.success) {
                    return;
                }

                var $ddl = $('#billNoDropdown');
                $ddl.empty();
                $ddl.append('<option value=""></option>');

                (res.data || []).forEach(function (b) {
                    var billNo = (b.BillNo !== undefined && b.BillNo !== null) ? (b.BillNo + '').trim() : '';
                    var tranDNo = (b.TranDNo !== undefined && b.TranDNo !== null) ? (b.TranDNo + '').trim() : '';

                    var disp = '';
                    if (billNo !== '' && tranDNo !== '') {
                        disp = tranDNo + '(' + billNo + ')';
                    } else if (billNo !== '') {
                        disp = billNo;
                    } else if (tranDNo !== '') {
                        disp = tranDNo;
                    }

                    if (disp !== '') {
                        $ddl.append('<option value="' + b.SalesOrderId + '">' + disp + '</option>');
                    }
                });

                $ddl.trigger('change');
            });
        }

        function loadSalesOrderData(soId) {
            $.get('@Url.Action("GetSalesOrderData", "SalesInvoiceFromSalesOrderOthers")', { salesOrderId: soId }, function (res) {
                if (!res || !res.success) {
                    return;
                }

                var h = res.header || {};
                $('#custNameOrAddr').val(h.CustomerName || h.Address1 || '');
                $('#custAddress1').val(h.Address1 || '');
                $('#custCity').val(h.City || '');
                $('#custState').val(h.State || '');
                $('#custPincode').val(h.Pincode || '');
                $('#custCountry').val(h.Country || '');
                $('#stateTypeDropdown').val((h.StateType !== undefined && h.StateType !== null) ? h.StateType : 0);

                var tbody = $('#invoiceDetailsBody');
                tbody.empty();

                (res.items || []).forEach(function (itm, idx) {
                    var tr = $('<tr>');
                    tr.append('<td class="text-center">' + (idx + 1) + '</td>');
                    tr.append('<td><input type="hidden" class="row-materialid" value="' + itm.MaterialId + '" /><input type="text" class="form-control form-control-sm" value="' + (itm.MaterialName || '') + '" readonly="readonly" /></td>');
                    tr.append('<td><input type="text" class="form-control form-control-sm" value="' + (itm.HsnCode || '') + '" readonly="readonly" /></td>');
                    tr.append('<td><input type="text" class="form-control form-control-sm" value="" readonly="readonly" /></td>');
                    tr.append('<td><input type="date" class="form-control form-control-sm" value="" /></td>');
                    tr.append('<td><select class="form-control form-control-sm">' + (packingOptionsHtml || '<option value=""></option>') + '</select></td>');
                    tr.append('<td><input type="number" class="form-control form-control-sm text-end" value="" min="0" step="1" /></td>');
                    tr.append('<td><input type="number" class="form-control form-control-sm text-end row-qty" value="' + (itm.Qty || 0) + '" min="0" step="0.001" readonly="readonly" /></td>');
                    tr.append('<td><input type="number" class="form-control form-control-sm text-end row-rate" value="" min="0" step="0.01" /></td>');
                    tr.append('<td><input type="number" class="form-control form-control-sm text-end row-actualrate" value="" min="0" step="0.01" /></td>');
                    tr.append('<td><input type="number" class="form-control form-control-sm text-end" value="" min="0" step="0.01" /></td>');
                    tr.append('<td><input type="text" class="form-control form-control-sm text-end row-amount" value="0.00" readonly="readonly" /></td>');
                    tbody.append(tr);
                });
            });
        }

        function recalcRow($tr) {
            var qty = parseFloat($tr.find('.row-qty').val() || '0');
            var rate = parseFloat($tr.find('.row-rate').val() || '0');
            if (isNaN(qty)) qty = 0;
            if (isNaN(rate)) rate = 0;

            var amount = qty * rate;
            $tr.find('.row-amount').val(amount.toFixed(2));
        }
    </script>
}
