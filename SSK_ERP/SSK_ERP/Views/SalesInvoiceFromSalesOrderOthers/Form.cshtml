                var h = res.header || {};
                var items = res.items || [];
                var taxJson = res.taxFactorsJson || '';

                $('#salesOrderId').val((h.SalesOrderId !== undefined && h.SalesOrderId !== null) ? h.SalesOrderId : 0);
                $('#tranRefId').val((h.CustomerId !== undefined && h.CustomerId !== null) ? h.CustomerId : 0);
                $('#tranRefName').val(h.CustomerName || '');

                $('#custNameOrAddr').val(h.CustomerName || h.Address1 || '');
                $('#custAddress1').val(h.Address1 || '');
                $('#custCity').val(h.City || '');
                $('#custState').val(h.State || '');
                $('#custPincode').val(h.Pincode || '');
                $('#custCountry').val(h.Country || '');
                $('#stateTypeDropdown').val((h.StateType !== undefined && h.StateType !== null) ? h.StateType : 0);

                suppressCustomerChange = true;
                $('#customerDropdown').val(h.CustomerId || '').trigger('change.select2');

                // Load saved Tax popup data (manual cost factors) if available
                try {
                    if (taxJson && (taxJson + '').trim() !== '') {
                        siTaxData = JSON.parse(taxJson);
                    } else {
                        siTaxData = [];
                    }
                } catch (e) {
                    siTaxData = [];
                }

                $('#siTaxDataJson').val(siTaxData && siTaxData.length ? JSON.stringify(siTaxData) : '');
                loadSiCostFactors(function () {
                    renderSiTaxRows(siTaxData);
                    updateManualSummaryFromRows(siTaxData);
                });

                // Render rows immediately so edit grid is not blocked by Bill No loading.
                renderInvoiceRows(items);
                recalcTotals();
                updateManualSummaryFromRows(siTaxData);
                var totalRows = $('#invoiceDetailsBody .row-select').length;
                var checkedRows = $('#invoiceDetailsBody .row-select:checked').length;
                $('#chkAll').prop('checked', totalRows > 0 && totalRows === checkedRows);

                loadBillNos(h.CustomerId || 0, function () {
                    if (h.SalesOrderId) {
                        suppressBillChange = true;
                        $('#billNoDropdown').val(h.SalesOrderId).trigger('change.select2');
                        $('#salesOrderId').val(h.SalesOrderId);
                    }

                    isLoadingEdit = false;
                });
            });
        }

