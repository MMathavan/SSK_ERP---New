@{ 
    ViewBag.Title = "Stock View";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .so-main-container {
        background: white;
        min-height: 100vh;
        padding: 20px 0;
    }

    .so-content-wrapper {
        background: white;
        border-radius: 15px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        margin: 20px;
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .so-header-section {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        color: white;
        padding: 25px 30px;
        border-radius: 15px 15px 0 0;
    }

    .so-header-title {
        font-size: 28px;
        font-weight: 600;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .so-table-container {
        padding: 30px;
        background: white;
    }
</style>

<div class="so-main-container">
    <div class="so-content-wrapper">
        <div class="so-header-section">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="so-header-title">
                    <i class="bi bi-card-list"></i>
                    Stock View
                </h1>
            </div>
        </div>

        <div class="so-table-container">
            <div class="row mb-3">
                <div class="col-md-3">
                    <label for="fromDate" class="form-label">From Date</label>
                    <input type="date" id="fromDate" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label for="toDate" class="form-label">To Date</label>
                    <input type="date" id="toDate" class="form-control" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="button" id="filterBtn" class="btn btn-primary me-2">
                        <i class="fa fa-filter"></i> Filter
                    </button>
                    <button type="button" id="clearBtn" class="btn btn-secondary">
                        <i class="fa fa-times"></i> Clear
                    </button>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div id="filterStatus" style="display:none;">
                        <small class="text-muted"><span id="filterText"></span></small>
                    </div>
                </div>
            </div>

            <div id="stockViewContent" class="border rounded p-3">
                <div class="text-muted">Select From/To date and click Filter.</div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            function toDateInputValue(dt) {
                try {
                    var yyyy = dt.getFullYear();
                    var mm = String(dt.getMonth() + 1).padStart(2, '0');
                    var dd = String(dt.getDate()).padStart(2, '0');
                    return yyyy + '-' + mm + '-' + dd;
                } catch (e) {
                    return '';
                }
            }

            var today = new Date();
            if (!$('#fromDate').val()) {
                $('#fromDate').val(toDateInputValue(today));
            }
            if (!$('#toDate').val()) {
                $('#toDate').val(toDateInputValue(today));
            }

            function updateFilterStatus() {
                var fromDate = $('#fromDate').val();
                var toDate = $('#toDate').val();
                var statusDiv = $('#filterStatus');
                var textSpan = $('#filterText');

                if (fromDate || toDate) {
                    var filterText = 'Filtered: ';
                    if (fromDate && toDate) {
                        filterText += fromDate + ' to ' + toDate;
                    } else if (fromDate) {
                        filterText += 'From ' + fromDate;
                    } else if (toDate) {
                        filterText += 'Until ' + toDate;
                    }
                    textSpan.text(filterText);
                    statusDiv.show();
                } else {
                    statusDiv.hide();
                }
            }

            $('#filterBtn').on('click', function () {
                var fromDate = $('#fromDate').val();
                var toDate = $('#toDate').val();

                if (fromDate && toDate && fromDate > toDate) {
                    alert('From Date cannot be greater than To Date');
                    return;
                }

                updateFilterStatus();
            });

            $('#clearBtn').on('click', function () {
                $('#fromDate').val('');
                $('#toDate').val('');
                updateFilterStatus();
            });
        });
    </script>
}
